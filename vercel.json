{
  "redirects": [
    { "source": "/rankings", "destination": "/discover", "permanent": true }
  ],
  "rewrites": [
    { "source": "/discover", "destination": "/index.html" },
    { "source": "/discover/(.*)", "destination": "/index.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/data/(.*)", "destination": "/data/$1" },
    { "source": "/creators", "destination": "/creators.html" },
    { "source": "/", "destination": "/home.html" },
    { "source": "/(.*)", "destination": "/home.html" }
  ]
}
